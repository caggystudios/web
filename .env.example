# Diisi OTOMATIS oleh Vercel saat kamu install integrasi Marketplace.
# Jangan commit file .env.local (yang isinya nilai asli) ke Git.

# Dari integrasi "Upstash Redis" (Storage > Marketplace Database Providers)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dari integrasi "Blob" (Storage > Create Database > Blob)
BLOB_READ_WRITE_TOKEN=
